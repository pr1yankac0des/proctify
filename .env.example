# ─── SMTP (optional) ─────────────────────────────────────────────────────────
# If not set, verification codes are printed to the API console (dev mode)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=AcademyFlow <your-email@gmail.com>

# ─── Database ─────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string — get this from atlas.mongodb.com (free M0 cluster)
# Without this, data is stored in server/data.json (lost on every Render restart)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/academyflow?retryWrites=true&w=majority
# Set to local to force server/data.json even when MONGODB_URI is present (useful for tests)
# DATA_STORE=local

# ─── Admin ────────────────────────────────────────────────────────────────────
# Password required to access /admin in the browser
# CHANGE THIS before deploying — default is admin1234
ADMIN_PASSWORD=admin1234

# ─── API ──────────────────────────────────────────────────────────────────────
API_PORT=3001

# ─── Production (set these on Render + Netlify) ───────────────────────────────
# On Render: set ALLOWED_ORIGIN to your Netlify URL, e.g. https://academyflow.netlify.app
ALLOWED_ORIGIN=https://your-app.netlify.app

# On Netlify: set VITE_API_URL to your Render backend URL, e.g. https://academyflow-api.onrender.com/api
VITE_API_URL=https://your-api.onrender.com/api
